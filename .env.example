# ShopEase WMS Backend — Environment Variables
# Copy this file to .env and fill in values

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/shopease_db?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────
WMS_JWT_SECRET=your-super-secret-wms-jwt-key-here-min-32-chars
WMS_JWT_EXPIRY=24h

# ─── Redis (for ShopEase ↔ WMS sync) ─────────────────────────
REDIS_URL=redis://localhost:6379
# On Render: redis://default:password@redis.onrender.com:6379

# ─── ShopEase Backend ────────────────────────────────────────
SHOPEASE_BACKEND_URL=https://shopease-backend-be8v.onrender.com
WMS_SHOPEASE_SECRET=shared-secret-between-shopease-and-wms

# ─── Courier APIs ────────────────────────────────────────────
DELHIVERY_API_KEY=
DELHIVERY_BASE_URL=https://track.delhivery.com/api

SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external

# ─── Firebase FCM ───────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Cloudinary (for QC images) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Server ──────────────────────────────────────────────────
PORT=8081
ENV=development
